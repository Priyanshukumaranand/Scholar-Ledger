# ============================================================
# Scholar Ledger — Backend env config
# Copy to backend/.env and fill in real values.
# ============================================================

# Server
PORT=4000
HOST=0.0.0.0
# Local dev: http://localhost:3000
# Prod:      https://your-frontend.vercel.app
CORS_ORIGIN=http://localhost:3000

# Blockchain RPC (read-only — no private key needed here)
# Local: http://127.0.0.1:7545
# Sepolia: https://sepolia.infura.io/v3/<your-key>
RPC_URL=http://127.0.0.1:7545

# Contract addresses (paste from `truffle migrate` output)
SCHOLAR_LEDGER_ADDRESS=
ISSUER_REGISTRY_ADDRESS=
STUDENT_PROFILE_REGISTRY_ADDRESS=
ACCREDITATION_REGISTRY_ADDRESS=

# IPFS gateway (used to fetch profile JSON for verifier endpoints)
IPFS_GATEWAY=https://ipfs.io/ipfs/

# Pinata (server-side IPFS pinning; keys live ONLY here, never on the frontend)
# Use either API key + secret OR JWT — JWT is preferred.
PINATA_JWT=
PINATA_API_KEY=
PINATA_SECRET_KEY=

# Email notifications (optional — leave RESEND_API_KEY empty to disable)
RESEND_API_KEY=
RESEND_FROM=Scholar Ledger <onboarding@resend.dev>

# Notify API token (must match the token an issuer enters in Issuer Settings → Email notifications)
# Generate a random 32+ char string and share it only with trusted issuers.
NOTIFY_API_TOKEN=
