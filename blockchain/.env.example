# ============================================================
# Scholar Ledger — Contract deployment env config
# Copy to blockchain/.env and fill in real values.
# This file is ONLY used when running `truffle migrate --network sepolia`.
# Local Ganache deploys ignore everything below.
# ============================================================

# Deployer account private key (the "Scholar Ledger Deployer" account in MetaMask).
# Paste it WITHOUT the 0x prefix. NEVER share or commit this file.
# This wallet must hold Sepolia ETH (get from a faucet — see README).
DEPLOYER_PRIVATE_KEY=

# Infura RPC key for Sepolia.
# Sign up free at https://app.infura.io → create a key → copy the part
# AFTER /v3/ in the Sepolia endpoint URL.
INFURA_KEY=
