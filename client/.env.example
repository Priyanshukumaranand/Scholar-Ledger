# ============================================================
# Scholar Ledger — Frontend env config
# Copy to client/.env and fill in real values.
# ============================================================

# IPFS pinning (Pinata)
REACT_APP_PINATA_API_KEY=
REACT_APP_PINATA_SECRET_KEY=

# Contract addresses (paste from `truffle migrate --reset` output)
REACT_APP_CONTRACT_ADDRESS=
REACT_APP_ISSUER_REGISTRY_ADDRESS=
REACT_APP_STUDENT_PROFILE_REGISTRY_ADDRESS=
REACT_APP_ACCREDITATION_REGISTRY_ADDRESS=

# Blockchain RPC (Ganache local default)
REACT_APP_RPC_URL=http://127.0.0.1:7545

# IPFS gateway (optional — defaults to https://ipfs.io/ipfs/)
# REACT_APP_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# Backend service URL (optional — used by Bulk Issue + Bulk Verify)
REACT_APP_BACKEND_URL=http://localhost:4000

# CRA: silences html5-qrcode source-map noise
GENERATE_SOURCEMAP=false
