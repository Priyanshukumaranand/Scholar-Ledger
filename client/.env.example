# ============================================================
# Scholar Ledger — Frontend env config
# Copy to client/.env and fill in real values.
# ============================================================

# Contract addresses (paste from `truffle migrate --network sepolia` output)
REACT_APP_CONTRACT_ADDRESS=
REACT_APP_ISSUER_REGISTRY_ADDRESS=
REACT_APP_STUDENT_PROFILE_REGISTRY_ADDRESS=
REACT_APP_ACCREDITATION_REGISTRY_ADDRESS=

# Blockchain RPC + chain id
# Local dev (Ganache): RPC_URL=http://127.0.0.1:7545  CHAIN_ID=1337
# Sepolia testnet:     RPC_URL=https://sepolia.infura.io/v3/<your-key>  CHAIN_ID=11155111
REACT_APP_RPC_URL=http://127.0.0.1:7545
REACT_APP_CHAIN_ID=1337

# Backend service URL (used by IPFS upload, bulk endpoints, notifications)
# Local: http://localhost:4000
# Prod:  https://your-backend.onrender.com
REACT_APP_BACKEND_URL=http://localhost:4000

# IPFS gateway (optional — defaults to https://ipfs.io/ipfs/)
# REACT_APP_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# CRA: disable source maps in production builds (don't ship original source)
GENERATE_SOURCEMAP=false
